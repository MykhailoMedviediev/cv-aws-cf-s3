node {
    stage('Checkout') {
        checkout(scm).each { k, v -> env.setProperty(k, v) }
        env.GIT_COMMIT_HASH = env.GIT_COMMIT.take(5)
    }

    try{
        stage('Parse yaml file') {
            def yaml = readYAML file: "cloud.yaml"
            yaml["env"].each {name, value ->
                env["$name"] = value
                echo "Setting environment variable ${key} to ${value}"
            } 
        }
    } catch (Throwable e) {
        throw e
    } finally {
        cleanWs()
    }
}