node {
    stage('Checkout') {
        checkout(scm).each { k, v -> env.setProperty(k, v) }
    }

    try{
        stage('Parse yaml file') {
            def yaml = readYaml file: "cloud.yaml"
            def terraform = [:]

            yaml.each { key, value ->
                terraform[key] = value
            }

            echo "terraform object - ${terraform}"
        }
    } catch (Throwable e) {
        throw e
    } finally {
        cleanWs()
    }
}